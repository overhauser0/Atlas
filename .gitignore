node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js (frontend)
.next/
out/
next-env.d.ts

# production / build outputs
build/
dist/

